# =============================================================================
# MANGU BOOK OS — Environment (aligned with my_publishing Mongo stack)
# =============================================================================
# Fastest path if you already bootstrapped my_publishing:
#   npm run db:mongo:import-uri -- "$MONGODB_URI_FROM_MY_PUBLISHING"
# That writes .env.local with db=mangu_book_os (separate from storefront "mangu").
#
# Or bootstrap Atlas the same way as my_publishing:
#   export ATLAS_PUBLIC_KEY=... ATLAS_PRIVATE_KEY=...
#   npm run db:mongo:up

ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
# ATLAS_ORG_ID=
# ATLAS_GROUP_ID=
# ATLAS_CLUSTER_NAME=Cluster0
# ATLAS_DB_USER=mangu_app
# ATLAS_PROJECT_NAME=mangu-publishers

MONGODB_URI=mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=mangu_book_os
DATABASE_PROVIDER=mongodb
AUTH_SECRET=

# Vercel sync (optional)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=team_hc9sovtwUu2WJdNuoU7JtWUP

API_PORT=3001
