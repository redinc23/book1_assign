{
  "name": "mangu-book-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx server/dev.ts",
    "dev:web": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "db:atlas:bootstrap": "tsx scripts/atlas-bootstrap.ts",
    "db:mongo:ping": "tsx scripts/mongo-ping.ts",
    "db:mongo:indexes": "tsx scripts/mongo-ensure-indexes.ts",
    "db:mongo:sync-vercel": "tsx scripts/sync-mongodb-to-vercel.ts",
    "db:mongo:up": "tsx scripts/mongo-up.ts",
    "db:mongo:import-uri": "tsx scripts/mongo-import-uri.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@vercel/functions": "^3.7.5",
    "bcryptjs": "^3.0.3",
    "digest-fetch": "^3.1.1",
    "hono": "^4.12.31",
    "jose": "^6.2.3",
    "lucide-react": "^0.344.0",
    "mongodb": "^7.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.4",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
